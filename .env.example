# surya batch sizes - tuned for RTX 4050 6GB
# bump RECOGNITION_BATCH_SIZE up to 48 or 64 if you have vram headroom
RECOGNITION_BATCH_SIZE=32
DETECTOR_BATCH_SIZE=4

# surya device - auto detects but explicit is safer
TORCH_DEVICE=cuda

QDRANT_URL=http://localhost: 1223
REDIS_URL=redis://localhost:1234/0